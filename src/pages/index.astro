---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import meta from '../../data/meta.json';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LogementsVacants.fr',
  url: 'https://logementsvacants.fr',
  description: 'Carte et statistiques des logements vacants en France par commune, département et région.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://logementsvacants.fr/recherche?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="Logements vacants en France — Carte et statistiques par commune"
  description={`${meta.nb_log_vacant?.toLocaleString('fr-FR')} logements vacants en France dont ${meta.nb_log_vacant_2ans?.toLocaleString('fr-FR')} depuis plus de 2 ans. Carte interactive et données LOVAC ${meta.millesime} par commune, département et région.`}
  schema={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Hero -->
    <section class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Logements vacants en France — Carte et statistiques par commune
      </h1>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Trouvez les logements vacants près de chez vous grâce aux données LOVAC {meta.millesime} du gouvernement
      </p>
    </section>

    <!-- Search bar -->
    <section class="max-w-2xl mx-auto mb-12">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="Rechercher une commune ou un département..."
          class="w-full px-4 py-3 rounded-lg border border-gray-300 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg"
          autocomplete="off"
        />
        <div id="search-results" class="absolute w-full bg-white border border-gray-200 rounded-b-lg shadow-lg mt-1 hidden z-50 max-h-80 overflow-y-auto"></div>
      </div>
    </section>

    <!-- National stats -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Chiffres clés — France entière</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard label="Logements vacants" value={meta.nb_log_vacant} color="orange" />
        <StatCard label="Vacants depuis + 2 ans" value={meta.nb_log_vacant_2ans} subtitle="Vacance structurelle" color="red" />
        <StatCard label="Taux de vacance" value={meta.taux_vacance ? `${meta.taux_vacance}%` : null} color="blue" />
        <StatCard label="Communes analysées" value={meta.nb_communes} subtitle={`Données au 1er janvier ${meta.millesime}`} color="green" />
      </div>
    </section>

    <!-- Top departments -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Top 10 départements les plus touchés</h2>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">#</th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Département</th>
              <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Taux vacance</th>
              <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Logements vacants</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {meta.top_departements?.map((dept, i) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 text-sm text-gray-500">{i + 1}</td>
                <td class="px-4 py-3">
                  <a href={`/logements-vacants/departement/${dept.slug}/`} class="text-blue-700 hover:underline font-medium">
                    {dept.nom} ({dept.code})
                  </a>
                </td>
                <td class="px-4 py-3 text-right font-semibold text-orange-600">{dept.taux_vacance}%</td>
                <td class="px-4 py-3 text-right text-gray-700">{dept.nb_log_vacant?.toLocaleString('fr-FR')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Map placeholder -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Carte de France des logements vacants</h2>
      <div id="map-home" class="w-full h-96 md:h-[500px] rounded-lg border border-gray-200 bg-gray-100"></div>
    </section>

    <!-- Explainer -->
    <section class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="bg-white rounded-lg p-6 shadow-sm">
        <h2 class="text-xl font-bold mb-3">C'est quoi un logement vacant ?</h2>
        <p class="text-gray-600">
          Un logement vacant est un logement inoccupé, proposé ou non à la vente ou à la location.
          On distingue la <strong>vacance frictionnelle</strong> (moins de 2 ans, liée à la rotation normale)
          de la <strong>vacance structurelle</strong> (plus de 2 ans, signal d'un problème : dégradation,
          succession bloquée, marché détendu...).
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-sm">
        <h2 class="text-xl font-bold mb-3">Comment sont calculés ces chiffres ?</h2>
        <p class="text-gray-600">
          Les données proviennent du fichier <strong>LOVAC {meta.millesime}</strong> (Logements Vacants),
          produit par le Cerema à partir du croisement des fichiers fonciers (DGFiP) et des fichiers
          de la taxe d'habitation. Le taux de vacance est le ratio logements vacants / parc privé total.
        </p>
      </div>
    </section>
  </div>

  <script>
    import Fuse from 'fuse.js';

    let fuse: any;
    let searchData: any;

    async function loadSearchIndex() {
      if (searchData) return;
      const resp = await fetch('/data/search-index.json');
      searchData = await resp.json();
      fuse = new Fuse(searchData, {
        keys: ['nom', 'code_insee', 'nom_dept'],
        threshold: 0.3,
      });
    }

    const input = document.getElementById('search-input') as HTMLInputElement;
    const results = document.getElementById('search-results')!;

    input?.addEventListener('focus', loadSearchIndex);
    input?.addEventListener('input', () => {
      const query = input.value.trim();
      if (!query || !fuse) { results.classList.add('hidden'); return; }
      const hits = fuse.search(query, { limit: 8 });
      if (hits.length === 0) { results.classList.add('hidden'); return; }
      results.innerHTML = hits.map(({ item }: any) =>
        `<a href="/logements-vacants/commune/${item.slug}/" class="block px-4 py-3 hover:bg-blue-50 border-b border-gray-100">
          <span class="font-medium">${item.nom}</span>
          <span class="text-sm text-gray-500 ml-2">${item.nom_dept} (${item.dept})</span>
          ${item.taux !== null ? `<span class="float-right text-sm font-semibold text-orange-600">${item.taux}%</span>` : ''}
        </a>`
      ).join('');
      results.classList.remove('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('#search-input, #search-results')) {
        results.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
