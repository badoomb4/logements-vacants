---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonical, ogImage, schema } = Astro.props;
const siteUrl = 'https://logementsvacants.fr';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImg = ogImage || `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="LogementsVacants.fr" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900">
    <!-- Navigation -->
    <header class="bg-white shadow-sm border-b border-gray-200">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <a href="/" class="text-xl font-bold text-blue-700 hover:text-blue-800">
              LogementsVacants.fr
            </a>
          </div>
          <div class="hidden md:flex items-center space-x-6">
            <a href="/" class="text-gray-600 hover:text-blue-700 transition-colors">Accueil</a>
            <a href="/carte" class="text-gray-600 hover:text-blue-700 transition-colors">Carte</a>
            <a href="/logements-vacants/departement/" class="text-gray-600 hover:text-blue-700 transition-colors">Départements</a>
            <a href="/logements-vacants/region/" class="text-gray-600 hover:text-blue-700 transition-colors">Régions</a>
            <a href="/blog/" class="text-gray-600 hover:text-blue-700 transition-colors">Blog</a>
            <a href="/a-propos" class="text-gray-600 hover:text-blue-700 transition-colors">À propos</a>
          </div>
          <!-- Mobile menu button -->
          <div class="md:hidden flex items-center">
            <button id="mobile-menu-btn" class="text-gray-600 hover:text-blue-700 p-2" aria-label="Menu">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <a href="/" class="block py-2 text-gray-600 hover:text-blue-700">Accueil</a>
          <a href="/carte" class="block py-2 text-gray-600 hover:text-blue-700">Carte</a>
          <a href="/logements-vacants/departement/" class="block py-2 text-gray-600 hover:text-blue-700">Départements</a>
          <a href="/logements-vacants/region/" class="block py-2 text-gray-600 hover:text-blue-700">Régions</a>
          <a href="/blog/" class="block py-2 text-gray-600 hover:text-blue-700">Blog</a>
          <a href="/a-propos" class="block py-2 text-gray-600 hover:text-blue-700">À propos</a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-semibold mb-3">LogementsVacants.fr</h3>
            <p class="text-sm">Données ouvertes sur les logements vacants en France. Source : LOVAC (Cerema / Ministère de la Transition écologique).</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Navigation</h3>
            <ul class="text-sm space-y-1">
              <li><a href="/carte" class="hover:text-white transition-colors">Carte interactive</a></li>
              <li><a href="/logements-vacants/departement/" class="hover:text-white transition-colors">Par département</a></li>
              <li><a href="/logements-vacants/region/" class="hover:text-white transition-colors">Par région</a></li>
              <li><a href="/comprendre-la-vacance" class="hover:text-white transition-colors">Comprendre la vacance</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Ressources</h3>
            <ul class="text-sm space-y-1">
              <li><a href="https://www.data.gouv.fr" target="_blank" rel="noopener" class="hover:text-white transition-colors">data.gouv.fr</a></li>
              <li><a href="https://zerologementvacant.beta.gouv.fr" target="_blank" rel="noopener" class="hover:text-white transition-colors">Zéro Logement Vacant</a></li>
              <li><a href="/a-propos" class="hover:text-white transition-colors">Mentions légales</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-6 text-sm text-center">
          <p>&copy; {new Date().getFullYear()} LogementsVacants.fr — Données LOVAC {new Date().getFullYear()} sous Licence Ouverte</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
